{
  "general": {
    "enableAutoUpdate": false
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "model": {
    "maxSubagentDepth": 1
  },
  "memory": {
    "enableManagedAutoMemory": false,
    "enableManagedAutoDream": false,
    "enableAutoSkill": false,
    "autoSkillConfirm": true,
    "enableTeamMemory": false,
    "enableTeamMemorySync": false
  },
  "tools": {
    "approvalMode": "default",
    "shell": {
      "enableInteractiveShell": false
    },
    "computerUse": {
      "enabled": false
    }
  },
  "permissions": {
    "ask": [
      "Edit",
      "Bash",
      "Agent",
      "WebFetch"
    ],
    "deny": [
      "Read(/**/.git/**)",
      "Edit(/**/.git/**)",
      "Read(/**/.env)",
      "Edit(/**/.env)",
      "Read(/**/.env.local)",
      "Edit(/**/.env.local)",
      "Read(/**/.env.development.local)",
      "Edit(/**/.env.development.local)",
      "Read(/**/.env.test.local)",
      "Edit(/**/.env.test.local)",
      "Read(/**/.env.production.local)",
      "Edit(/**/.env.production.local)",
      "Read(/**/*.p12)",
      "Edit(/**/*.p12)",
      "Read(/**/*.pfx)",
      "Edit(/**/*.pfx)",
      "Read(/**/*.jks)",
      "Edit(/**/*.jks)",
      "Read(/**/*.keystore)",
      "Edit(/**/*.keystore)",
      "Read(/**/*.mobileprovision)",
      "Edit(/**/*.mobileprovision)",
      "Read(/**/*.pem)",
      "Edit(/**/*.pem)",
      "Read(/**/*.key)",
      "Edit(/**/*.key)",
      "Read(/**/local.properties)",
      "Edit(/**/local.properties)",
      "Read(/**/key.properties)",
      "Edit(/**/key.properties)"
    ]
  },
  "slashCommands": {
    "disabled": [
      "mcp",
      "extensions"
    ]
  },
  "mcp": {
    "allowed": [],
    "excluded": [
      "*"
    ]
  },
  "security": {
    "folderTrust": {
      "enabled": true
    }
  },
  "telemetry": {
    "enabled": false,
    "logPrompts": false,
    "includeSensitiveSpanAttributes": false
  },
  "experimental": {
    "cron": false,
    "agentTeam": false,
    "artifact": false
  },
  "disableAllHooks": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Read|ReadFile|Grep|Glob|ListFiles|Write|WriteFile|Edit|EditFile|NotebookEdit|Bash|Shell|read_file|read_many_files|grep_search|glob|list_directory|write_file|edit|notebook_edit|run_shell_command)$",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$QWEN_PROJECT_DIR/.qwen/hooks/secret-and-protected-file-guard.py\"",
            "name": "secret-and-protected-file-guard",
            "description": "Block secret, signing, protected, outside-project, and traversal paths.",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 \"$QWEN_PROJECT_DIR/.qwen/hooks/dangerous-mobile-command-guard.py\"",
            "name": "dangerous-mobile-command-guard",
            "description": "Block destructive commands and require review for high-impact local operations.",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 \"$QWEN_PROJECT_DIR/.qwen/hooks/release-signing-publishing-guard.py\"",
            "name": "release-signing-publishing-guard",
            "description": "Block signing, publishing, upload, submission, distribution, and deployment commands.",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 \"$QWEN_PROJECT_DIR/.qwen/hooks/sensitive-change-review.py\"",
            "name": "sensitive-change-review",
            "description": "Require human review for sensitive mobile configuration and security-boundary changes.",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/web-development-department.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "provider_agnostic",
    "default_state",
    "runtime_binding",
    "runtime_selection_required",
    "provider_selection_required",
    "model_selection_required",
    "instructions",
    "roles_directory",
    "skills_directory",
    "workflows_directory",
    "policies",
    "quality_gates"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "const": "web-development"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "provider_agnostic": {
      "type": "boolean",
      "const": true
    },
    "default_state": {
      "type": "string",
      "const": "disabled"
    },
    "runtime_binding": {
      "type": "string",
      "const": "none"
    },
    "runtime_selection_required": {
      "type": "boolean",
      "const": true
    },
    "provider_selection_required": {
      "type": "boolean",
      "const": true
    },
    "model_selection_required": {
      "type": "boolean",
      "const": true
    },
    "instructions": {
      "type": "string",
      "const": "instructions.md"
    },
    "roles_directory": {
      "type": "string",
      "const": "roles"
    },
    "skills_directory": {
      "type": "string",
      "const": "skills"
    },
    "workflows_directory": {
      "type": "string",
      "const": "workflows"
    },
    "quality_gates": {
      "type": "string",
      "const": "quality-gates.md"
    },
    "policies": {
      "type": "object",
      "required": [
        "permissions",
        "integrations"
      ],
      "properties": {
        "permissions": {
          "type": "string",
          "const": "policies/permissions.json"
        },
        "integrations": {
          "type": "string",
          "const": "policies/integrations.json"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "schemaVersion": 1,
  "nonEnforcementDisclaimer": "This file is declarative policy only. A separate user-selected runtime must implement enforcement.",
  "default": "deny",
  "capabilities": {
    "readWorkspace": "ask",
    "writeWorkspace": "ask",
    "executeCommands": "deny",
    "installDependencies": "deny",
    "gitMutation": "deny",
    "networkAccess": "ask",
    "externalIntegrations": "deny",
    "mcp": "deny",
    "deploy": "deny",
    "publish": "deny",
    "destructiveActions": "deny"
  },
  "leastPrivilegeCategories": {
    "implementationRoles": [
      "readWorkspace",
      "writeWorkspace"
    ],
    "reviewerRoles": [
      "readWorkspace"
    ],
    "leadRole": [
      "readWorkspace",
      "delegateWithinSpecification"
    ]
  },
  "explicitDeniedOperations": [
    "executeCommands",
    "installDependencies",
    "gitMutation",
    "deploy",
    "publish",
    "mcp",
    "externalIntegrations",
    "destructiveActions",
    "credentialUse",
    "secretExposure"
  ],
  "humanApprovalRequired": [
    "authentication",
    "authorization",
    "secrets",
    "sensitiveData",
    "databaseMigration",
    "dependencies",
    "thirdPartyScripts",
    "tracking",
    "production",
    "deployment",
    "publication",
    "billing",
    "destructiveActions"
  ]
}

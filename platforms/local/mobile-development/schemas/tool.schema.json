{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tool.schema.json",
  "type": "object",
  "required": ["manifest_type", "schema", "id", "classification", "purpose", "allowed_operations", "denied_operations", "inputs", "outputs", "approval_required", "fail_safe_behavior"],
  "properties": {
    "manifest_type": {"const": "tool-contract"},
    "schema": {"type": "string", "pattern": "^\\.\\./schemas/tool\\.schema\\.json$"},
    "id": {"type": "string"},
    "classification": {"enum": ["native", "unsupported"]},
    "purpose": {"type": "string", "minLength": 1},
    "allowed_operations": {"$ref": "#/$defs/nonEmptyStringArray"},
    "denied_operations": {"$ref": "#/$defs/nonEmptyStringArray"},
    "inputs": {"$ref": "#/$defs/nonEmptyStringArray"},
    "outputs": {"$ref": "#/$defs/nonEmptyStringArray"},
    "approval_required": {"type": "boolean"},
    "fail_safe_behavior": {"type": "string", "minLength": 1},
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "extensions": {
      "type": "object",
      "propertyNames": {"pattern": "^(x|provider|runtime|host|vendor)_[A-Za-z0-9][A-Za-z0-9_.-]*$"},
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "matcher": "bash|powershell|create|edit|apply_patch|str_replace_editor",
        "bash": "python3 .github/hooks/scripts/secret-and-protected-file-guard.py",
        "powershell": "py -3 .github/hooks/scripts/secret-and-protected-file-guard.py",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "matcher": "bash|powershell",
        "bash": "python3 .github/hooks/scripts/dangerous-mobile-command-guard.py",
        "powershell": "py -3 .github/hooks/scripts/dangerous-mobile-command-guard.py",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "matcher": "bash|powershell",
        "bash": "python3 .github/hooks/scripts/release-signing-publishing-guard.py",
        "powershell": "py -3 .github/hooks/scripts/release-signing-publishing-guard.py",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "matcher": "create|edit|apply_patch|str_replace_editor",
        "bash": "python3 .github/hooks/scripts/sensitive-change-review.py",
        "powershell": "py -3 .github/hooks/scripts/sensitive-change-review.py",
        "timeoutSec": 10
      }
    ]
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "skill": "allow",
    "edit": "ask",
    "write": "ask",
    "apply_patch": "ask",
    "bash": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "mcp_*": "deny"
  },
  "mcp": {
    "context7": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  }
}

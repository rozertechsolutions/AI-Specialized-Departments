{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/codex/mobile-development/.codex/hooks/prompt-secret-guard.py\"",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; & py -3 (Join-Path $root 'codex/mobile-development/.codex/hooks/prompt-secret-guard.py')\"",
            "timeout": 10,
            "statusMessage": "Checking prompt for secrets"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/codex/mobile-development/.codex/hooks/prompt-secret-guard.py\"",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; & py -3 (Join-Path $root 'codex/mobile-development/.codex/hooks/prompt-secret-guard.py')\"",
            "timeout": 10,
            "statusMessage": "Checking change for secrets"
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/codex/mobile-development/.codex/hooks/mobile-command-guard.py\"",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; & py -3 (Join-Path $root 'codex/mobile-development/.codex/hooks/mobile-command-guard.py')\"",
            "timeout": 10,
            "statusMessage": "Checking mobile device command"
          },
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/codex/mobile-development/.codex/hooks/release-permission-guard.py\"",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; & py -3 (Join-Path $root 'codex/mobile-development/.codex/hooks/release-permission-guard.py')\"",
            "timeout": 10,
            "statusMessage": "Checking signing and publication policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/codex/mobile-development/.codex/hooks/sensitive-change-guard.py\"",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; & py -3 (Join-Path $root 'codex/mobile-development/.codex/hooks/sensitive-change-guard.py')\"",
            "timeout": 10,
            "statusMessage": "Checking for sensitive mobile changes"
          }
        ]
      }
    ]
  }
}

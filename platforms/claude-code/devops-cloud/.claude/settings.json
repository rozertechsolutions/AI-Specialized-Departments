{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "plan",
  "disableBypassPermissionsMode": "disable",
  "permissions": {
    "deny": [
      "Bash",
      "Edit",
      "Write",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "mcp__*",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*secret*)",
      "Read(./**/*credential*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  }
}

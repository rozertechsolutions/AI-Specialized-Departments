{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow.schema.json",
  "type": "object",
  "required": ["manifest_type", "id", "classification", "objective", "trigger", "inputs", "supported_technologies", "preconditions", "primary_owner", "reviewers", "steps", "validation_gates", "failures", "stop_conditions", "evidence", "outputs", "acceptance_criteria", "human_approvals", "prohibited_actions"],
  "properties": {
    "manifest_type": {"const": "workflow"},
    "id": {"type": "string"},
    "classification": {"enum": ["native", "unsupported"]}
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local.schema.json",
  "type": "object",
  "required": ["manifest_type", "schema", "id", "version", "surface", "classification"],
  "properties": {
    "manifest_type": {"const": "local-specialization"},
    "schema": {"type": "string", "pattern": "^schemas/local\\.schema\\.json$"},
    "id": {"type": "string"},
    "version": {"type": "string"},
    "surface": {"type": "string"},
    "status": {"enum": ["native", "unsupported"]},
    "scope": {
      "type": "object",
      "required": ["root", "technologies", "forbidden_paths"],
      "properties": {
        "root": {"const": "local/mobile-development"},
        "technologies": {"$ref": "#/$defs/nonEmptyStringArray"},
        "forbidden_paths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "classification": {
      "type": "object",
      "required": ["native", "unsupported"],
      "properties": {
        "native": {"$ref": "#/$defs/nonEmptyStringArray"},
        "unsupported": {"$ref": "#/$defs/nonEmptyStringArray"}
      },
      "additionalProperties": false
    },
    "precedence": {"$ref": "#/$defs/nonEmptyStringArray"},
    "delegation": {
      "type": "object",
      "required": ["coordinator", "specialists_directory", "max_depth", "final_review", "self_review_prohibited"],
      "properties": {
        "coordinator": {"type": "string", "pattern": "^agents/[A-Za-z0-9_.-]+\\.ya?ml$"},
        "specialists_directory": {"type": "string", "minLength": 1},
        "max_depth": {"type": "integer"},
        "final_review": {"type": "string", "minLength": 1},
        "self_review_prohibited": {"const": true}
      },
      "additionalProperties": false
    },
    "capability_negotiation": {
      "type": "object",
      "required": ["provider_routing", "remote_use_requires_explicit_consent", "no_silent_cloud_fallback", "unknown_capability_behavior"],
      "properties": {
        "provider_routing": {"type": "string", "minLength": 1},
        "remote_use_requires_explicit_consent": {"const": true},
        "no_silent_cloud_fallback": {"const": true},
        "unknown_capability_behavior": {"const": "fail_closed"}
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "required": ["discovery", "activation", "external_integrations_default", "audit_logging"],
      "properties": {
        "discovery": {"const": "validate_manifests_before_use"},
        "activation": {"type": "string", "minLength": 1},
        "external_integrations_default": {"const": "disabled"},
        "audit_logging": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["schema_directory", "hook_tests", "malformed_security_config"],
      "properties": {
        "schema_directory": {"const": "schemas"},
        "hook_tests": {"type": "string", "minLength": 1},
        "malformed_security_config": {"const": "fail_closed"}
      },
      "additionalProperties": false
    },
    "references": {
      "type": "object",
      "properties": {
        "official_documentation": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "extensions": {
      "type": "object",
      "propertyNames": {"pattern": "^(x|provider|runtime|host|vendor)_[A-Za-z0-9][A-Za-z0-9_.-]*$"},
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

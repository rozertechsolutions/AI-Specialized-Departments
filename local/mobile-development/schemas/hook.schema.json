{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hook.schema.json",
  "type": "object",
  "required": ["manifest_type", "classification", "hooks", "fail_safe_behavior"],
  "properties": {
    "manifest_type": {"const": "hooks"},
    "classification": {"enum": ["native", "unsupported"]},
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "file", "event", "mode", "modifies_source", "uses_network"]
      }
    }
  },
  "additionalProperties": true
}

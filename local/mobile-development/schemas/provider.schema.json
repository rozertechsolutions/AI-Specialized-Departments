{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "provider.schema.json",
  "type": "object",
  "required": ["manifest_type", "schema", "id", "classification", "enabled", "provider_kind", "capability_discovery", "configuration", "remote_use_requires_explicit_consent"],
  "properties": {
    "manifest_type": {"const": "provider"},
    "schema": {"type": "string", "pattern": "^\\.\\./schemas/provider\\.schema\\.json$"},
    "id": {"type": "string"},
    "classification": {"enum": ["native", "unsupported"]},
    "enabled": {"const": false},
    "provider_kind": {"type": "string", "minLength": 1},
    "official_docs": {"type": ["string", "null"]},
    "capability_discovery": {"const": "required_at_runtime"},
    "configuration": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "api_key": {"type": "null"}
      },
      "additionalProperties": {
        "type": ["string", "number", "boolean", "array", "object", "null"]
      }
    },
    "remote_use_requires_explicit_consent": {"const": true},
    "notes": {"type": "string", "minLength": 1},
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "$defs": {
    "extensions": {
      "type": "object",
      "propertyNames": {"pattern": "^(x|provider|runtime|host|vendor)_[A-Za-z0-9][A-Za-z0-9_.-]*$"},
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
